# vim: set filetype=swayconfig :
gaps inner 0
# do not use gaps for a single window
smart_gaps on
# do nto use borders for a single window
smart_borders on
# this would also remove window titles
default_border pixel 3

font pango:JetBrainsMono Nerd Font 9

# ---
# colors
# ---
set $col_bg #16161e
set $col_bg_dark #11111a
set $col_surface #1f2335
set $col_surface2 #24283b
set $col_border #3b4261
set $col_border_muted #292e42
set $col_text #c0caf5
set $col_text_muted #9aa5ce
set $col_focus #7aa2f7
set $col_focus_dim #3d59a1
set $col_indicator #e0af68
set $col_urgent #f7768e
set $col_urgent_dim #914c54

# ---
# sway colors
# ---

set $focused_border $col_focus
set $focused_background $col_surface2
set $focused_text $col_text
set $focused_indicator $col_indicator
set $focused_child_border $col_focus

set $inactive_border $col_border
set $inactive_background $col_surface
set $inactive_text $col_text_muted
set $inactive_indicator $col_border
set $inactive_child_border $col_border_muted

set $urgent_border $col_urgent
set $urgent_background $col_urgent_dim
set $urgent_text $col_text
set $urgent_indicator $col_urgent
set $urgent_child_border $col_urgent

set $unfocused_border $col_border_muted
set $unfocused_background $col_bg
set $unfocused_text $col_text_muted
set $unfocused_indicator $col_border_muted
set $unfocused_child_border $col_border_muted

client.focused $focused_border $focused_background $focused_text $focused_indicator $focused_child_border
client.focused_inactive $inactive_border $inactive_background $inactive_text $inactive_indicator $inactive_child_border
client.unfocused $unfocused_border $unfocused_background $unfocused_text $unfocused_indicator $unfocused_child_border
client.urgent $urgent_border $urgent_background $urgent_text $urgent_indicator $urgent_child_border
