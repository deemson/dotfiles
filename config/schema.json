{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "inherit": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "abstract": {
      "type": "boolean"
    },
    "apps": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "paths": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "system": {
                  "type": "string",
                  "minLength": 1
                },
                "repo": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "system",
                "repo"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "name",
          "paths"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "apps"
  ],
  "additionalProperties": false
}